{
  "name": "aossh",
  "version": "1.3.7",
  "description": "AOS SSH & SFTP Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.aossh.app",
    "productName": "AOSSH",
    "icon": "icon.ico",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  }
}
