{
  "name": "aossh",
  "version": "1.3.8",
  "description": "AOS SSH & SFTP Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "test": "node --test \"test/unit/**/*.test.js\"",
    "e2e": "playwright test"
  },
  "dependencies": {
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0",
    "xterm-addon-canvas": "^0.5.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-unicode11": "^0.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.aossh.app",
    "productName": "AOSSH",
    "icon": "icon.ico",
    "files": [
      "**/*",
      "!test/**",
      "!playwright.config.js",
      "!test-results/**",
      "!playwright-report/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  }
}
